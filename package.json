{
  "name": "sereus-workspace",
  "version": "0.6.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "description": "Sereus monorepo",
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "@optimystic/quereus-plugin-crypto": "link:../optimystic/packages/quereus-plugin-crypto",
    "@optimystic/quereus-plugin-optimystic": "link:../optimystic/packages/quereus-plugin-optimystic",
    "@optimystic/db-core": "link:../optimystic/packages/db-core",
    "@optimystic/demo": "link:../optimystic/packages/demo",
    "@optimystic/db-p2p": "link:../optimystic/packages/db-p2p",
    "@optimystic/db-p2p-storage-rn": "link:../optimystic/packages/db-p2p-storage-rn",
    "@optimystic/db-p2p-storage-web": "link:../optimystic/packages/db-p2p-storage-web",
    "@quereus/quereus": "link:../quereus/packages/quereus"
  },
  "scripts": {
    "clean": "yarn workspaces foreach -A run clean",
    "build": "yarn workspaces foreach -At run build",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "test:all": "yarn workspaces foreach -A run test:all",
    "dep-check": "yarn workspaces foreach -A run dep-check",
    "doc": "yarn workspaces foreach -A run doc",
    "typecheck": "yarn workspaces foreach -A run typecheck",
    "bump": "bumpp --recursive",
    "release": "yarn bump && yarn pub",
    "pub": "yarn pub:strand-proto && yarn pub:cadre-core && yarn pub:cadre-cli && yarn pub:cadre-provider",
    "pub:strand-proto": "node scripts/publish-package.js strand-proto",
    "pub:cadre-core": "node scripts/publish-package.js cadre-core",
    "pub:cadre-cli": "node scripts/publish-package.js cadre-cli",
    "pub:cadre-provider": "node scripts/publish-package.js cadre-provider",
    "upgrade:optimystic": "ncu -u --workspaces --filter '/@optimystic/.*/'",
    "upgrade:quereus": "ncu -u --workspaces --filter '/@quereus/.*/'"
  },
  "devDependencies": {
    "bumpp": "^10.4.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3"
  }
}
