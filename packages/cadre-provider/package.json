{
  "name": "@serfab/cadre-provider",
  "version": "0.6.0",
  "type": "module",
  "description": "Reference provider service for hosting Sereus cadre nodes on behalf of users",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/bin/provider.js",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/sereus.git",
    "directory": "packages/cadre-provider"
  },
  "keywords": [
    "sereus",
    "cadre",
    "provider",
    "distributed",
    "p2p",
    "hosting"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "dev:test": "vitest",
    "start": "node dist/bin/provider.js"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/dockerode": "^3.3.31",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.10",
    "aegir": "^45.2.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@serfab/cadre-core": "workspace:^",
    "commander": "^14.0.2",
    "debug": "^4.4.3",
    "dockerode": "^4.0.9",
    "fastify": "^5.7.1",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "",
  "license": "MIT"
}
