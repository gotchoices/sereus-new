{
  "name": "@sereus/cadre-provider",
  "version": "0.0.1",
  "type": "module",
  "description": "Reference provider service for hosting Sereus cadre nodes on behalf of users",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/bin/provider.js",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "dev:test": "vitest",
    "start": "node dist/bin/provider.js"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^22.13.10",
    "aegir": "^45.1.4",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@sereus/cadre-core": "^0.0.1",
    "commander": "^12.0.0",
    "debug": "^4.3.4",
    "dockerode": "^4.0.2",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.7"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "",
  "license": "MIT"
}
