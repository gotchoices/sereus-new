{
  "name": "@sereus/cadre-core",
  "version": "0.0.1",
  "type": "module",
  "description": "Core library for Sereus cadre nodes - manages control networks and strand participation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/sereus.git",
    "directory": "packages/cadre-core"
  },
  "author": "Got Choices Foundation",
  "license": "MIT",
  "keywords": [
    "sereus",
    "cadre",
    "core",
    "distributed",
    "p2p",
    "libp2p"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "dev:test": "vitest"
  },
  "devDependencies": {
    "@chainsafe/libp2p-noise": "^16.1.5",
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@libp2p/tcp": "^10.1.19",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.0.10",
    "aegir": "^45.2.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/interface": "^2.11.0",
    "@libp2p/peer-id": "^5.1.9",
    "@optimystic/db-core": "^0.1.0",
    "@optimystic/db-p2p": "^0.1.1",
    "@optimystic/quereus-plugin-crypto": "^0.3.0",
    "@optimystic/quereus-plugin-optimystic": "^0.3.0",
    "@quereus/quereus": "^0.15.1",
    "debug": "^4.4.3",
    "libp2p": "^2.10.0",
    "uint8arrays": "^5.1.0"
  }
}
