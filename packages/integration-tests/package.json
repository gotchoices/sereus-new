    "@libp2p/tcp": "^10.1.18",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.13.10",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@libp2p/crypto": "^5.0.14",
    "@libp2p/interface": "^2.10.5",
    "@libp2p/peer-id": "^5.1.8",
    "@optimystic/db-core": "^0.0.1",
    "@optimystic/db-p2p": "^0.0.1",
    "@optimystic/quereus-plugin-crypto": "^0.3.0",
    "@optimystic/quereus-plugin-optimystic": "^0.3.0",
    "@quereus/quereus": "^0.13.1",
    "@sereus/cadre-core": "workspace:*",
    "debug": "^4.4.1",
    "libp2p": "^2.9.0",
    "uint8arrays": "^5.1.0"
