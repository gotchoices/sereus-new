{
  "name": "@sereus/integration-tests",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Integration tests for Sereus cadre system - tests real networking, storage, and multi-party scenarios",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --reporter=verbose",
