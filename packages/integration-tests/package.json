    "@libp2p/tcp": "^10.1.19",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.0.10",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/interface": "^2.11.0",
    "@libp2p/peer-id": "^5.1.9",
    "@optimystic/db-core": "^0.1.0",
    "@optimystic/db-p2p": "^0.1.1",
    "@optimystic/quereus-plugin-crypto": "^0.3.0",
    "@optimystic/quereus-plugin-optimystic": "^0.3.0",
    "@quereus/quereus": "^0.15.1",
    "@sereus/cadre-core": "workspace:*",
    "debug": "^4.4.3",
    "libp2p": "^2.10.0",
    "uint8arrays": "^5.1.0"
