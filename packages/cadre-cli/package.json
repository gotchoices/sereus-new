{
  "name": "@sereus/cadre-cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI wrapper for Sereus cadre nodes - start, monitor, and manage cadre node instances",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cadre": "dist/bin/cadre.js"
  },
  "files": [
    "src",
    "dist",
    "!dist/test",
    "!**/*.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gotchoices/sereus.git",
    "directory": "packages/cadre-cli"
  },
  "author": "Got Choices Foundation",
  "license": "MIT",
  "keywords": [
    "sereus",
    "cadre",
    "cli",
    "distributed",
    "p2p"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "dev:test": "vitest",
    "start": "node dist/bin/cadre.js"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.10",
    "aegir": "^45.2.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@sereus/cadre-core": "workspace:^",
    "commander": "^14.0.2",
    "debug": "^4.4.3",
    "js-yaml": "^4.1.1",
    "uint8arrays": "^5.1.0"
  }
}
