# Sereus Cadre Node Environment Configuration
# Copy this file to .env and customize for your deployment

# ============================================================================
# REQUIRED: Control Network Identity
# ============================================================================

# Your party UUID (identifies your control network)
CADRE_PARTY_ID=

# Bootstrap nodes to connect to (comma-separated multiaddrs)
# Example: /dns4/bootstrap.example.com/tcp/4001/p2p/12D3KooW...,/ip4/1.2.3.4/tcp/4001/p2p/12D3KooW...
CADRE_BOOTSTRAP_NODES=

# ============================================================================
# Node Profile
# ============================================================================

# Node profile: 'storage' (server) or 'transaction' (edge/mobile)
# Default: storage
CADRE_PROFILE=storage

# Storage quota in bytes (optional, only for storage profile)
# Example: 10737418240 (10 GB)
CADRE_STORAGE_QUOTA=

# ============================================================================
# Network Configuration
# ============================================================================

# Addresses to listen on (comma-separated)
# Default: /ip4/0.0.0.0/tcp/4001
CADRE_LISTEN_ADDRS=/ip4/0.0.0.0/tcp/4001

# Addresses to announce externally (comma-separated)
# Use if behind NAT or proxy. Example: /dns4/mynode.example.com/tcp/4001
CADRE_ANNOUNCE_ADDRS=

# Relay servers for NAT traversal (comma-separated)
# Example: /dns4/relay.example.com/tcp/4001/p2p/12D3KooW...
CADRE_RELAY_ADDRS=

# ============================================================================
# Host Port Bindings
# ============================================================================

# Host port for libp2p (maps to container port 4001)
HOST_P2P_PORT=4001

# Host port for health check endpoint
HOST_HEALTH_PORT=8080

# Host port for Prometheus metrics
HOST_METRICS_PORT=9090

# ============================================================================
# Strand Filtering (Optional)
# ============================================================================

# Filter which strands this node participates in
# Options: all, none, or JSON object like {"sAppId":"..."} or {"strandId":"..."}
# Default: all (participate in all strands)
CADRE_STRAND_FILTER=

# ============================================================================
# Hibernation Settings
# ============================================================================

# Enable strand hibernation for idle strands
CADRE_HIBERNATION_ENABLED=true

# Default latency hint: realtime, interactive, background, archive
CADRE_LATENCY_HINT=interactive

# Strand watcher polling interval in milliseconds
CADRE_STRAND_WATCH_INTERVAL=5000

# ============================================================================
# Resource Limits
# ============================================================================

# Maximum memory for container (Docker memory limit)
CONTAINER_MEMORY_LIMIT=4G

# ============================================================================
# Debug & Development
# ============================================================================

# Enable debug logging (set to any non-empty value to enable)
# CADRE_DEBUG=1

# ============================================================================
# Provider Integration (Optional)
# ============================================================================

# Enrollment token from provider (for automated enrollment)
# CADRE_ENROLLMENT_TOKEN=

# Provider API endpoint for status reporting
# CADRE_PROVIDER_API=

# Provider API key
# CADRE_PROVIDER_API_KEY=

