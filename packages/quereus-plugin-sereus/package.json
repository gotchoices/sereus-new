{
	"name": "@serfab/quereus-plugin-sereus",
	"version": "0.5.0",
	"type": "module",
	"description": "Quereus plugin that connects to a Sereus strand for SQL access",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"src",
		"dist",
		"!dist/test",
		"!**/*.tsbuildinfo"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"import": "./dist/plugin.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gotchoices/sereus.git",
		"directory": "packages/quereus-plugin-sereus"
	},
	"author": "Got Choices Foundation",
	"license": "MIT",
	"keywords": [
		"quereus-plugin",
		"quereus",
		"sereus",
		"strand",
		"distributed",
		"database",
		"sql",
		"p2p"
	],
	"scripts": {
		"clean": "rimraf dist",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"dev:test": "vitest"
	},
	"devDependencies": {
		"@types/debug": "^4.1.12",
		"@types/node": "^25.0.10",
		"rimraf": "^6.1.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17"
	},
	"dependencies": {
		"@libp2p/interface": "^3.1.0",
		"@optimystic/db-core": "^0.12.0",
		"@optimystic/db-p2p": "^0.12.0",
		"@optimystic/quereus-plugin-crypto": "^0.12.0",
		"@optimystic/quereus-plugin-optimystic": "^0.11.3",
		"@quereus/quereus": "^2.7.0",
		"debug": "^4.4.3"
	},
	"quereus": {
		"provides": {
			"vtables": [
				"optimystic"
			],
			"functions": [
				"StampId",
				"digest",
				"sign",
				"verify",
				"randomBytes"
			]
		},
		"settings": [
			{
				"key": "strand_id",
				"type": "string"
			},
			{
				"key": "bootstrap_nodes",
				"type": "string",
				"default": ""
			},
			{
				"key": "schema",
				"type": "string"
			},
			{
				"key": "sapp_id",
				"type": "string",
				"default": "unknown"
			},
			{
				"key": "sapp_version",
				"type": "string",
				"default": "1.0.0"
			},
			{
				"key": "port",
				"type": "number",
				"default": 0
			},
			{
				"key": "enable_cache",
				"type": "boolean",
				"default": true
			},
			{
				"key": "fret_profile",
				"type": "string",
				"default": "edge"
			}
		]
	}
}
