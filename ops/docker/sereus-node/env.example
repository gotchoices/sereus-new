# Sereus Cadre Node Configuration
# Copy this file to .env and configure the required settings

# ============================================================================
# REQUIRED SETTINGS
# ============================================================================

# Your party UUID (identifies your control network)
# Get this from your Sereus dashboard or party creation
CADRE_PARTY_ID=

# Bootstrap nodes for your control network (comma-separated multiaddrs)
# Example: /ip4/1.2.3.4/tcp/4001/p2p/12D3KooW...
CADRE_BOOTSTRAP_NODES=

# ============================================================================
# NODE PROFILE
# ============================================================================

# Node profile: storage (default) or transaction
# - storage: Optimized for data storage and replication
# - transaction: Optimized for transaction processing
CADRE_PROFILE=storage

# ============================================================================
# STORAGE SETTINGS
# ============================================================================

# Maximum storage quota (e.g., 100GB, 1TB). Empty = unlimited
CADRE_STORAGE_QUOTA=

# ============================================================================
# NETWORK SETTINGS
# ============================================================================

# Host ports to expose (change if ports conflict)
HOST_P2P_PORT=4001
HOST_HEALTH_PORT=8080
HOST_METRICS_PORT=9090

# External addresses to announce (for NAT traversal)
# Example: /ip4/YOUR_PUBLIC_IP/tcp/4001
CADRE_ANNOUNCE_ADDRS=

# Relay servers for NAT traversal (comma-separated multiaddrs)
CADRE_RELAY_ADDRS=

# ============================================================================
# HIBERNATION SETTINGS
# ============================================================================

# Enable hibernation mode (reduces resource usage when idle)
CADRE_HIBERNATION_ENABLED=true

# Latency hint: interactive (faster wake) or background (more aggressive sleep)
CADRE_LATENCY_HINT=interactive

# ============================================================================
# STRAND FILTER (OPTIONAL)
# ============================================================================

# Only participate in specific strands (comma-separated strand IDs)
# Leave empty to participate in all strands
CADRE_STRAND_FILTER=

# ============================================================================
# PROVIDER INTEGRATION (OPTIONAL)
# ============================================================================

# Provider API endpoint for status reporting
CADRE_PROVIDER_API=

# Enrollment token for automated enrollment
CADRE_ENROLLMENT_TOKEN=

# ============================================================================
# DEBUG
# ============================================================================

# Enable debug logging (set to any value to enable)
CADRE_DEBUG=


